# Deploy-time defaults only. Whatever is saved in Settings > Supabase
# database (this browser's localStorage) takes priority over these at
# runtime, so a single build can be pointed at different projects per
# browser without a rebuild — these vars just give it something to fall
# back to before anyone has configured the page.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
